{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChatSummarizeOutput",
  "description": "Session summary for expired/closed conversations",
  "type": "object",
  "required": ["summary"],
  "properties": {
    "summary": {
      "type": "string",
      "description": "2-3 sentence summary of the conversation",
      "maxLength": 1000
    }
  }
}
