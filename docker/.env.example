# Donna Environment Configuration
# Copy to .env (gitignored) and fill in values
# Run 'donna setup' for interactive guided configuration

# === [Phase 1] API Keys ===
ANTHROPIC_API_KEY=sk-ant-...

# === [Phase 1] Discord ===
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_TASKS_CHANNEL_ID=
DISCORD_DIGEST_CHANNEL_ID=
DISCORD_AGENTS_CHANNEL_ID=
DISCORD_DEBUG_CHANNEL_ID=

# === [Phase 1] Storage Paths ===
DONNA_DATA_PATH=/donna
DONNA_DB_PATH=/donna/db
DONNA_WORKSPACE_PATH=/donna/workspace
DONNA_BACKUP_PATH=/donna/backups
DONNA_LOG_PATH=/donna/logs

# === [Phase 1] Cost Management ===
DONNA_MONTHLY_BUDGET_USD=100.00
DONNA_DAILY_PAUSE_THRESHOLD_USD=20.00

# === [Phase 1] Grafana ===
GRAFANA_ADMIN_PASSWORD=changeme

# === [Phase 2] Twilio SMS/Voice ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DONNA_USER_PHONE=

# === [Phase 2] Google APIs ===
GOOGLE_CREDENTIALS_PATH=/donna/config/google_credentials.json
GOOGLE_CALENDAR_PERSONAL_ID=primary
GOOGLE_CALENDAR_WORK_ID=
GOOGLE_CALENDAR_FAMILY_ID=

# === [Phase 2] Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === [Phase 3] GPU Assignment ===
IMMICH_ML_GPU_ID=0          # GTX 1080 — dedicated to Immich/media
DONNA_OLLAMA_GPU_ID=1       # RTX 3090 — dedicated to Donna LLM

# === [Phase 4] Firebase (REST API auth) ===
FIREBASE_PROJECT_ID=
DONNA_DEFAULT_USER_ID=nick
DONNA_USER_MAP=
DONNA_AUTH_DISABLED=true
