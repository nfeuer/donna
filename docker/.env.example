# Donna Environment Configuration
# Copy to .env (gitignored) and fill in values
# Run 'donna setup' for interactive guided configuration

# === [Phase 1] API Keys ===
ANTHROPIC_API_KEY=sk-ant-...

# === [Phase 1] Discord ===
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_TASKS_CHANNEL_ID=
DISCORD_DIGEST_CHANNEL_ID=
DISCORD_AGENTS_CHANNEL_ID=
DISCORD_DEBUG_CHANNEL_ID=

# Required when manual_escalation.enabled=true (config/manual_escalation.yaml).
# Set to your own Discord user ID — only this account can resolve over-budget
# escalation buttons (slice 17 / docs/superpowers/specs/manual-escalation.md §10.1).
DONNA_OWNER_DISCORD_ID=

# === [Phase 1] Storage Paths ===
DONNA_DATA_PATH=/donna
DONNA_DB_PATH=/donna/db
DONNA_WORKSPACE_PATH=/donna/workspace
DONNA_BACKUP_PATH=/donna/backups
DONNA_LOG_PATH=/donna/logs

# Slice 21 — claude_code mode poller reads the host repo (read-only)
# at this path to verify branches, diff scope, and read committed
# files via `git show`. When unset or pointing at a non-git path the
# claude_code button is not offered (logged once, fail-soft).
# See docs/superpowers/specs/manual-escalation.md §5.3.
DONNA_HOST_REPO_PATH=/donna/host_repo

# === [Phase 1] Cost Management ===
DONNA_MONTHLY_BUDGET_USD=100.00
DONNA_DAILY_PAUSE_THRESHOLD_USD=20.00

# === [Phase 1] Grafana ===
GRAFANA_ADMIN_PASSWORD=changeme

# === [Phase 2] Twilio SMS/Voice ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DONNA_USER_PHONE=

# === [Phase 2] Google APIs ===
# Must match your DONNA_DATA_PATH — update if you changed the root above.
GOOGLE_CREDENTIALS_PATH=/donna/config/google_credentials.json
GOOGLE_CALENDAR_PERSONAL_ID=primary
GOOGLE_CALENDAR_WORK_ID=
GOOGLE_CALENDAR_FAMILY_ID=
# Set to true in Docker — disables interactive OAuth browser flow and
# requires a pre-provisioned token.json (see docs/scheduling.md).
# Run 'python -m donna.integrations.calendar' locally first to generate
# the token, then mount it at GOOGLE_CREDENTIALS_PATH/../token.json.
DONNA_HEADLESS=true

# === [Phase 2] Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === [Phase 3] GPU Assignment ===
# Single-GPU: set both to 0 (or omit IMMICH_ML_GPU_ID if not running Immich).
# Multi-GPU: assign different indices to avoid VRAM contention.
IMMICH_ML_GPU_ID=0          # GPU for Immich ML (if applicable)
DONNA_OLLAMA_GPU_ID=0       # GPU for Donna local LLM (RTX 3090)

# === [Phase 4] Auth (Immich-gated) ===
# Immich admin API key with "read users" scope — used to sync the
# allowed-emails list. Required at startup; API refuses to boot without it.
IMMICH_ADMIN_API_KEY=
# Bootstrap: first user whose Immich email matches this value is auto-
# promoted to admin on initial login. Remove after bootstrap is complete.
DONNA_BOOTSTRAP_ADMIN_EMAIL=
# Default user ID for internal/automated requests (e.g. Docker-internal traffic).
DONNA_DEFAULT_USER_ID=
# Set to true to disable Immich auth entirely (dev/testing only).
DONNA_AUTH_DISABLED=false
# CORS must be a concrete allowlist or unset (same-origin via Caddy).
# Setting this to '*' is refused at startup because auth uses cookies.
# DONNA_CORS_ORIGINS=

# === Domain / URLs ===
# Used in auth.yaml to construct Immich OAuth redirect, magic-link emails,
# and the admin access-revocation URL. Set these to your real domain.
DONNA_EXTERNAL_URL=https://donna.example.com
DONNA_IMMICH_EXTERNAL_URL=https://immich.example.com
DONNA_EMAIL_FROM=donna@example.com

# === [Slice 12] Obsidian Vault ===
# Host path for the markdown vault. Mounted into donna-orchestrator at
# /donna/vault and served over WebDAV by the donna-vault Caddy service.
DONNA_VAULT_PATH=/donna/vault
# Basic auth for the WebDAV endpoint (Caddy `basic_auth`). Generate the
# password hash with `caddy hash-password -p <plaintext>`.
CADDY_VAULT_USER=donna
CADDY_VAULT_PASSWORD_HASH=

# === [Phase 3] Local LLM (Ollama) ===
# Base URL for Ollama server (Docker service name resolves in homelab network)
DONNA_OLLAMA_URL=http://donna-ollama:11434
# Model tag to pull/use (must be pre-pulled in the donna-ollama container)
DONNA_OLLAMA_MODEL=qwen2.5:32b-instruct-q4_K_M
# Timeout for Ollama API calls in seconds (default: 120)
# DONNA_OLLAMA_TIMEOUT_S=120

# === [Optional] Storage Overrides ===
# Override individual storage paths (defaults derived from DONNA_DATA_PATH)
# DONNA_BACKUP_DIR=/donna/backups
# DONNA_LOGS_DB_PATH=/donna/db/donna_logs.db
# DONNA_DB_DIR=/donna/db

# === [Optional] Monitoring ===
# Loki push URL for structured log shipping (default: http://donna-loki:3100)
# DONNA_LOKI_URL=http://donna-loki:3100
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# DONNA_LOG_LEVEL=INFO
# Enable human-readable logs instead of JSON (default: false)
# DONNA_DEV_MODE=false

# === [Optional] Networking ===
# Base URL for internal service-to-service calls
# DONNA_HOST_BASE_URL=http://localhost:8100
# Trusted CIDR ranges for internal traffic (comma-separated)
# DONNA_INTERNAL_CIDRS=172.16.0.0/12,10.0.0.0/8

# === [Optional] Twilio Advanced ===
# Webhook URL for inbound SMS verification
# TWILIO_WEBHOOK_URL=https://donna.example.com/sms/webhook

# === [Optional] Email Monitoring ===
# Email address to poll for forwarded task emails (requires Gmail API)
# DONNA_EMAIL_MONITOR_ALIAS=
