{
  "title": "Memory Vault",
  "uid": "donna-memory",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["donna", "memory", "vault"],
  "panels": [
    {
      "id": 1,
      "title": "Retrieval Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "quantile_over_time(0.5, {container_name=\"donna-orchestrator\"} | json | event=\"memory_retrieval\" | unwrap latency_ms [5m])",
          "legendFormat": "p50"
        },
        {
          "datasource": "Loki",
          "expr": "quantile_over_time(0.95, {container_name=\"donna-orchestrator\"} | json | event=\"memory_retrieval\" | unwrap latency_ms [5m])",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 2,
      "title": "Chunks Ingested (batches)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum(count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"memory_ingest_batch\" [$__range]))",
          "legendFormat": "batches"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] }
      }
    },
    {
      "id": 3,
      "title": "Re-embeds (chunk)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum(count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"llm_invocation_logged\" | task_type=\"embed_vault_chunk\" [$__range]))",
          "legendFormat": "chunks embedded"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] }
      }
    },
    {
      "id": 4,
      "title": "Vault Watch Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum by (change) (count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"vault_watch_event\" [5m]))",
          "legendFormat": "{{change}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Retrieval Hits per Query",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "avg_over_time({container_name=\"donna-orchestrator\"} | json | event=\"memory_retrieval\" | unwrap hits [5m])",
          "legendFormat": "avg hits"
        }
      ]
    },
    {
      "id": 6,
      "title": "Episodic ingest events (slice 14)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum by (event) (count_over_time({container_name=\"donna-orchestrator\"} | json | event=~\"memory_ingest_(chat_turn|task|correction)\" [5m]))",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Embed calls by task_type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum by (task_type) (count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"llm_invocation_logged\" | task_type=~\"embed_(vault_chunk|chat_turn|task|correction|memory_query)\" [5m]))",
          "legendFormat": "{{task_type}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Per-source ingest latency p50",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "quantile_over_time(0.5, {container_name=\"donna-orchestrator\"} | json | event=~\"memory_ingest_(chat_turn|task|correction)\" | unwrap latency_ms [5m]) by (source_type)",
          "legendFormat": "p50 {{source_type}}"
        },
        {
          "datasource": "Loki",
          "expr": "quantile_over_time(0.95, {container_name=\"donna-orchestrator\"} | json | event=~\"memory_ingest_(chat_turn|task|correction)\" | unwrap latency_ms [5m]) by (source_type)",
          "legendFormat": "p95 {{source_type}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Memory ingest failures",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 38 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum by (source_type) (count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"memory_ingest_failed\" [$__range]))",
          "legendFormat": "{{source_type}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] }
      }
    },
    {
      "id": 10,
      "title": "Template writes (slice 15+16)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 46 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum by (template) (count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"vault_autowrite_written\" [5m]))",
          "legendFormat": "written {{template}}"
        },
        {
          "datasource": "Loki",
          "expr": "sum by (template) (count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"vault_autowrite_skipped_idempotent\" [5m]))",
          "legendFormat": "skipped {{template}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Template-write skip rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 46 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum(count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"vault_autowrite_skipped_idempotent\" [$__range])) / clamp_min(sum(count_over_time({container_name=\"donna-orchestrator\"} | json | event=~\"vault_autowrite_(written|skipped_idempotent)\" [$__range])), 1)",
          "legendFormat": "idempotent skip rate"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["last"] }
      }
    },
    {
      "id": 12,
      "title": "Autowrite LLM cost by task_type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 54 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum by (task_type) (sum_over_time({container_name=\"donna-orchestrator\"} | json | event=\"llm_invocation_logged\" | task_type=~\"draft_meeting_note|draft_daily_reflection|draft_weekly_review|draft_person_profile|extract_commitments\" | unwrap cost_usd [5m]))",
          "legendFormat": "{{task_type}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Template autowrite failures",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 38 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum by (template) (count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"vault_autowrite_failed\" [$__range]))",
          "legendFormat": "{{template}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] }
      }
    },
    {
      "id": 14,
      "title": "Person stubs created per day (slice 16)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 62 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum(count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"person_stub_created\" [1h]))",
          "legendFormat": "stubs (1h)"
        }
      ]
    },
    {
      "id": 15,
      "title": "Vault renames matched vs. flushed (slice 16)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 62 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum(count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"vault_rename_matched\" [5m]))",
          "legendFormat": "matched (rename)"
        },
        {
          "datasource": "Loki",
          "expr": "sum(count_over_time({container_name=\"donna-orchestrator\"} | json | event=\"vault_rename_flushed_as_delete\" [5m]))",
          "legendFormat": "flushed (delete)"
        }
      ]
    }
  ]
}
